@model ClientSettingsDashboardViewModel

<h2>Client Settings</h2>

<form method="post" asp-action="Delete" onsubmit="return confirm('Are you sure you want to delete client settings?');">
    <button class="btn btn-danger mt-3">
        <i class="fa fa-trash"></i> Delete Client Settings
    </button>
    <form asp-action="ResetSettings" method="post">
        <button type="submit" class="btn btn-danger">Reset to Default</button>
    </form>
</form>

<form method="post" asp-action="Save">

    <div class="mb-3">
        <label>Client Name</label>
        <input id="ClientName" class="form-control" name="ClientName"
               value="@(Model.Settings?.ClientName ?? "")"
               oninput="updatePreview()" />
    </div>

    <div class="mb-3">
        <label>Theme Color</label>
        <input id="ThemeColor" type="color" class="form-control"
               name="ThemeColor"
               value="@(Model.Settings?.ThemeColor ?? "#007bff")"
               oninput="updatePreview()" />
    </div>

    <select asp-for="Settings.ThemeName" class="form-control">
        <option value="theme1">Theme 1 (Blue Modern)</option>
        <option value="theme2">Theme 2 (Elegant Gold)</option>
        <option value="theme3">Theme 3 (Soft Purple)</option>
        <option value="DarkPremium"> DarkPremium</option>
        <option value="EmeraldGreen">EmeraldGreen</option>
        <option value="OceanBlue">OceanBlue </option>
        <option value="RoyalGold">RoyalGold</option>
        <option value="themeDarkNeon">themeDarkNeon</option>
        <option value="themeEmeraldGreen">themeEmeraldGreen</option>
        <option value="themeRoyalRed">themeRoyalRed</option>
        <option value="THEMEUltraModernPremium">THEMEUltraModernPremium</option>

    </select>


    <div class="mb-3">
        <label>Choose Logo</label>
        <div class="d-flex flex-wrap">
            @foreach (var logo in Model.Logos)
            {
                <label class="me-3">
                    <input type="radio"
                           asp-for="Settings.LogoPath"
                           value="@logo"
                           onclick="previewLogo('@logo')"
                           checked="@(logo == Model.Settings?.LogoPath)" />

                    <img src="@logo"
                         style="height:60px; border:1px solid #ccc; margin:5px;" />
                </label>

                             
            }
        </div>
    </div>

    <button class="btn btn-primary">Save Settings</button>
</form>
@if (User.IsInRole("SuperAdmin"))
{
<hr />

<h3>Live Preview</h3>

<div class="p-3 border rounded" style="max-width:300px;">
    <img id="previewLogo" src="@(Model.Settings?.LogoPath ?? "/uploads/logos/default.png")" style="height:60px;" />
    <h4 id="previewName">@(Model.Settings?.ClientName ?? "")</h4>
</div>

<script>
    function updatePreview() {
        document.getElementById("previewName").innerText =
            document.getElementById("ClientName").value;

        document.documentElement.style.setProperty(
            '--theme-color',
            document.getElementById("ThemeColor").value
        );
    }

    function previewLogo(path) {
        document.getElementById("previewLogo").src = path;
    }
</script>

<hr />

<h2>License Dashboard</h2>

<div class="row">
    @foreach (var item in Model.Licenses)
    {
        var daysLeft = (item.ExpirationDate - DateTime.UtcNow).Days;

        <div class="col-md-4">
            <div class="card shadow-sm mb-3">
                <div class="card-header text-white" style="background-color: var(--theme-color);">
                    @item.ClientName
                </div>
                <div class="card-body">
                    <p><strong>Domain:</strong> @item.Domain</p>
                    <p><strong>Key:</strong> @item.LicenseKey</p>
                    <p><strong>Expiration:</strong> @item.ExpirationDate</p>
                    <p><strong>Days Left:</strong> @daysLeft</p>

                    @if (!item.IsActive)
                    {
                        <span class="badge bg-danger">Disabled</span>
                    }
                    else if (item.ExpirationDate < DateTime.UtcNow)
                    {
                        <span class="badge bg-danger">Expired</span>
                    }
                    else if (daysLeft <= 30)
                    {
                        <span class="badge bg-warning text-dark">Expiring Soon</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </div>
            </div>
        </div>
    }
</div>
}