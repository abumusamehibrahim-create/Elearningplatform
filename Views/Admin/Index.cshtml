@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = "_AdminLayout";
}

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small mb-1">إجمالي الطلاب</div>
                    <div class="stat-number text-danger">@ViewBag.TotalStudents</div>
                </div>
                <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-users fa-2x text-danger"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small mb-1">إجمالي الإيرادات</div>
                    <div class="stat-number text-success">$@ViewBag.TotalRevenue</div>
                </div>
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-dollar-sign fa-2x text-success"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small mb-1">الكورسات</div>
                    <div class="stat-number text-primary">@ViewBag.TotalCourses</div>
                </div>
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-book fa-2x text-primary"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted small mb-1">الفيديوهات</div>
                    <div class="stat-number text-warning">@ViewBag.TotalVideos</div>
                </div>
                <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                    <i class="fas fa-video fa-2x text-warning"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="stat-card text-center py-5">
            <i class="fas fa-book fa-3x text-danger mb-3"></i>
            <h5 class="fw-bold">إدارة الكورسات</h5>
            <p class="text-muted">أضف كورسات جديدة وارفع الفيديوهات</p>
            <a asp-controller="Admin" asp-action="Courses" class="btn btn-danger px-4">
                <i class="fas fa-arrow-left me-2"></i>إدارة الكورسات
            </a>
        </div>
    </div>
    <div class="col-md-6">
        <div class="stat-card text-center py-5">
            <i class="fas fa-users fa-3x text-primary mb-3"></i>
            <h5 class="fw-bold">الطلاب والمدفوعات</h5>
            <p class="text-muted">عرض جميع المدفوعات وبيانات الطلاب</p>
            <a asp-controller="Admin" asp-action="Students" class="btn btn-primary px-4">
                <i class="fas fa-arrow-left me-2"></i>عرض الطلاب
            </a>
            <a asp-controller="Admin" asp-action="PaymentList" class="btn btn-warning px-4">
                <i class="fas fa-money-bill me-2"></i> مراجعة المدفوعات
            </a>
            <a asp-controller="Admin" asp-action="PageVisits" class="btn btn-info px-4 mt-2">
                <i class="fas fa-eye me-2"></i> سجل الصفحات
            </a>


        </div>
    </div>
</div>

