@model ELearningPlatform.Models.Course
@{
    ViewData["Title"] = "إنشاء كورس جديد";
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="stat-card">
            <h5 class="fw-bold mb-4"><i class="fas fa-plus-circle me-2 text-danger"></i>إنشاء كورس جديد</h5>

            <form asp-action="CreateCourse" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label fw-semibold">عنوان الكورس <span class="text-danger">*</span></label>
                    <input asp-for="Title" class="form-control form-control-lg"
                           placeholder="مثال: دورة ASP.NET Core الشاملة" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">وصف الكورس <span class="text-danger">*</span></label>
                    <textarea asp-for="Description" class="form-control" rows="4"
                              placeholder="اكتب وصفاً تفصيلياً للكورس..." required></textarea>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">السعر (بالدولار) <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Price" type="number" step="0.01" min="0"
                               class="form-control form-control-lg" placeholder="99.00" required />
                    </div>
                </div>

                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                        <label class="form-check-label fw-semibold" asp-for="IsActive">نشر الكورس فوراً</label>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">صورة الكورس</label>
                    <input type="file" name="thumbnail" class="form-control" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger btn-lg px-5">
                        <i class="fas fa-save me-2"></i>حفظ الكورس
                    </button>
                    <a asp-controller="Admin" asp-action="Courses" class="btn btn-outline-secondary btn-lg">
                        إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
