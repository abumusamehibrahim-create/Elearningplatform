@model ELearningPlatform.Models.Video
@{
    ViewData["Title"] = Model.Title;
    var streamUrl = $"/Video/StreamLocal/{Model.Id}";
}

<div class="alert alert-warning m-3">
    <h5>🔍 معلومات الفيديو:</h5>
    <p><strong>Video ID:</strong> @Model.Id</p>
    <p><strong>Video Title:</strong> @Model.Title</p>
    <p><strong>Video FileName:</strong> @Model.FileName</p>
    <p><strong>Stream URL:</strong> @streamUrl</p>
    <p><strong>User Authenticated:</strong> @User.Identity.IsAuthenticated</p>
</div>

<div style="background:#000;">
    <div class="container px-0">
        <video id="videoPlayer" controls width="100%" style="max-height:70vh;"></video>
    </div>
</div>

<script>
    const video = document.getElementById('videoPlayer');
    video.src = '@streamUrl';

    video.addEventListener('error', () => {
        console.error('Video error:', video.error);
    });

    video.addEventListener('loadstart', () => console.log('Loading...'));
    video.addEventListener('canplay', () => console.log('Ready'));
</script>