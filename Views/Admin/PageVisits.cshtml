@model List<PageVisitLog>

@{
    ViewData["Title"] = "سجل الصفحات التي شاهدها المستخدمون";
}

<h2 class="mb-4">📄 سجل الصفحات التي شاهدها المستخدمون</h2>

<form method="get" class="row mb-4">

    <div class="col-md-3">
        <label>اسم المستخدم</label>
        <input type="text" name="user" class="form-control" value="@ViewBag.UserFilter" />
    </div>

    <div class="col-md-3">
        <label>من تاريخ</label>
        <input type="date" name="from" class="form-control" value="@ViewBag.FromFilter" />
    </div>

    <div class="col-md-3">
        <label>إلى تاريخ</label>
        <input type="date" name="to" class="form-control" value="@ViewBag.ToFilter" />
    </div>

    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-primary w-100">بحث</button>
    </div>

</form>
<div class="row mb-3">
    <div class="col-md-4">
        <div class="alert alert-info text-center">
            عدد السجلات: @Model.Count
        </div>
    </div>

    <div class="col-md-4">
        <div class="alert alert-secondary text-center">
            عدد المستخدمين: @Model.Select(x => x.UserName).Distinct().Count()
        </div>
    </div>

    <div class="col-md-4">
        <div class="alert alert-secondary text-center">
            عدد الصفحات المختلفة: @Model.Select(x => x.PageUrl).Distinct().Count()
        </div>
    </div>
</div>

<div class="alert alert-warning text-center">
    آخر زيارة: @Model.Max(x => x.VisitTime).ToLocalTime().ToString("yyyy-MM-dd HH:mm")
</div>

<table class="table table-bordered table-striped">
    <thead class="table-dark">
        <tr>
            <th>المستخدم</th>
            <th>الرابط</th>
            <th>عنوان الصفحة</th>
            <th>وقت الزيارة</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.UserName</td>
                <td>@log.PageUrl</td>
                <td>@log.PageTitle</td>
                <td>@log.VisitTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
            </tr>
        }
    </tbody>
</table>
<div class="mt-3 alert alert-info text-center">
    عدد السجلات: @Model.Count
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning text-center">
        لا توجد نتائج مطابقة للبحث.
    </div>
}
