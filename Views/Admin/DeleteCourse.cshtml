@model ELearningPlatform.Models.Course
@{
    ViewData["Title"] = "حذف الكورس";
    Layout = "_AdminLayout";
}

<div class="card shadow-sm p-4">

    <h3 class="text-danger fw-bold mb-3">
        <i class="fas fa-exclamation-triangle me-2"></i>
        هل أنت متأكد من حذف هذا الكورس؟
    </h3>

    <div class="row">
        <div class="col-md-3">
            @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
            {
                <img src="/thumbnails/@Model.ThumbnailUrl" class="img-fluid rounded shadow" />
            }
            else
            {
                <div class="text-muted small">لا توجد صورة</div>
            }
        </div>

        <div class="col-md-9">
            <h4 class="fw-bold">@Model.Title</h4>
            <p class="text-muted">@Model.Description</p>

            <ul class="list-group mb-3">
                <li class="list-group-item">
                    <strong>السعر:</strong> $@Model.Price
                </li>
                <li class="list-group-item">
                    <strong>عدد الفيديوهات:</strong> @Model.Videos.Count
                </li>
                <li class="list-group-item">
                    <strong>الحالة:</strong>
                    @(Model.IsActive ? "نشط" : "موقوف")
                </li>
            </ul>

            <div class="alert alert-danger">
                سيتم حذف جميع الفيديوهات والملفات التابعة لهذا الكورس بشكل نهائي.
            </div>

            <form asp-action="ConfirmDeleteCourse" method="post">
                <input type="hidden" name="id" value="@Model.Id" />

                <button class="btn btn-danger px-4">
                    <i class="fas fa-trash me-2"></i>تأكيد الحذف
                </button>

                <a asp-action="Courses" class="btn btn-secondary px-4 ms-2">
                    إلغاء
                </a>
            </form>
        </div>
    </div>

</div>
