@model IEnumerable<ELearningPlatform.Models.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "إدارة المستخدمين";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>إدارة المستخدمين</h3>
        <a asp-action="CreateUser" class="btn btn-success">
            <i class="bi bi-person-plus"></i> إضافة مستخدم جديد
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-info text-center">@TempData["Message"]</div>
    }

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>اسم المستخدم</th>
                <th>الإيميل</th>
                <th>الأدوار</th>
                <th>إدارة</th>
            </tr>
        </thead>
        <tbody>

            @foreach (var user in Model)
            {
                var roles = await UserManager.GetRolesAsync(user);

                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>

                    <!-- عرض الأدوار مع Badges + Icons -->
                    <td>
                        @foreach (var role in roles)
                        {
                            <span class="badge
                                        @(role == "SuperAdmin" ? "bg-danger" :
                                                                    role == "Admin" ? "bg-primary" :
                                                                    role == "Instructor" ? "bg-success" :
                                                                    role == "Support" ? "bg-warning text-dark" :
                                                                    role == "Finance" ? "bg-info text-dark" :
                                                                    "bg-secondary")">

                        @if (role == "SuperAdmin")
                                {
                                    <i class="bi bi-shield-lock"></i>
                                }
                                else if (role == "Admin")
                                {

                                    <i class="bi bi-person-gear"></i>
                                }
                                else if (role == "Instructor")
                                {

                                    <i class="bi bi-mortarboard"></i>
                                }
                                else if (role == "Support")
                                {

                                    <i class="bi bi-headset"></i>
                                }
                                else if (role == "Finance")
                                {

                                    <i class="bi bi-cash-coin"></i>
                                }

                                @role
                            </span>
                        }
                    </td>

                    <td>
                        <a asp-action="EditRoles" asp-route-id="@user.Id" class="btn btn-primary btn-sm">
                            <i class="bi bi-shield"></i> تعديل الأدوار
                        </a>

                        <a asp-action="ResetPassword" asp-route-id="@user.Id" class="btn btn-warning btn-sm">
                            <i class="bi bi-key"></i> إعادة تعيين كلمة المرور
                        </a>

                        <!-- منع حذف السوبر أدمن -->
                        @if (!roles.Contains("SuperAdmin"))
                        {
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('هل أنت متأكد من حذف هذا المستخدم؟');">
                                <button class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> حذف
                                </button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">لا يمكن حذف SuperAdmin</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
