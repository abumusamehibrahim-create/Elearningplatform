@model ELearningPlatform.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-warning text-dark text-center py-3">
            <h3 class="mb-0">تغيير كلمة المرور</h3>
        </div>

        <div class="card-body p-4">

            @if (TempData["Message"] != null)
            {
                <div class="alert alert-success text-center">@TempData["Message"]</div>
            }

            <form asp-action="ChangePassword" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">كلمة المرور الحالية</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control form-control-lg" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">كلمة المرور الجديدة</label>
                    <input asp-for="NewPassword" type="password" class="form-control form-control-lg" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">تأكيد كلمة المرور الجديدة</label>
                    <input asp-for="ConfirmNewPassword" type="password" class="form-control form-control-lg" />
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>

                <div class="text-center mt-4">
                    <button class="btn btn-primary px-5 py-2">
                        <i class="bi bi-shield-lock"></i> تغيير كلمة المرور
                    </button>

                    <a asp-action="Index" class="btn btn-secondary px-4 py-2 ms-2">
                        <i class="bi bi-arrow-right"></i> رجوع
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>
