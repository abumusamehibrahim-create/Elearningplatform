<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة التحكم</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
                body { font-family: 'Segoe UI', Tahoma, Arial, sans-serif; }
   

        .admin-sidebar { background: #1a1a2e; min-height: 100vh; width: 240px; position: fixed; top: 0; right: 0; z-index: 100; }
        .admin-sidebar .brand { padding: 20px; border-bottom: 1px solid rgba(255,255,255,.1); }
        .admin-sidebar a { color: #9ca3af; text-decoration: none; display: flex; align-items: center; gap: 10px; padding: 12px 20px; border-radius: 8px; margin: 2px 10px; transition: all .2s; }
        .admin-sidebar a:hover, .admin-sidebar a.active { background: #e74c3c; color: white; }
        .admin-sidebar a .icon { width: 20px; text-align: center; }
        .main-content { margin-right: 240px; padding: 0; }
        .topbar { background: white; padding: 15px 30px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
        .content-area { padding: 30px; background: #f8f9fa; min-height: calc(100vh - 65px); }
        .stat-card { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 2px 10px rgba(0,0,0,.06); transition: transform .2s; }
        .stat-card:hover { transform: translateY(-3px); }
        .stat-number { font-size: 2rem; font-weight: bold; }
        .table-card { background: white; border-radius: 12px; box-shadow: 0 2px 10px rgba(0,0,0,.06); overflow: hidden; }
        .btn-danger { background: #e74c3c; border-color: #e74c3c; }
        .btn-danger:hover { background: #c0392b; border-color: #c0392b; }

        /* Sidebar hidden by default */
        .admin-sidebar {
            right: -240px;
            transition: right 0.3s ease;
        }

            /* When active → show */
            .admin-sidebar.active {
                right: 0;
            }

        /* Overlay */
        #overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 90;
        }

            #overlay.show {
                display: block;
            }

        /* Main content always full width */
        .main-content {
            margin-right: 0 !important;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="admin-sidebar">
        <div class="brand">
            <a href="/Admin" class="text-white text-decoration-none d-flex align-items-center gap-2" style="font-size:1.1rem;font-weight:bold;">
                <i class="fas fa-graduation-cap text-danger"></i>لوحة التحكم
            </a>
        </div>
        <nav class="mt-3">
            <a asp-controller="Admin" asp-action="Index"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <span class="icon"><i class="fas fa-tachometer-alt"></i></span> الرئيسية
            </a>
            <a asp-controller="Admin" asp-action="Courses"
               class="@(ViewContext.RouteData.Values["action"]?.ToString()?.StartsWith("Course") == true ? "active" : "")">
                <span class="icon"><i class="fas fa-book"></i></span> الكورسات
            </a>
            <a asp-controller="Admin" asp-action="Students"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Students" ? "active" : "")">
                <span class="icon"><i class="fas fa-users"></i></span> الطلاب والمدفوعات
            </a>

            <a asp-controller="Admin" asp-action="Students" class="btn btn-dark px-4">
                <i class="fas fa-arrow-left me-2"></i>عرض الطلاب
            </a>

            <a asp-controller="Admin" asp-action="PaymentList" class="btn btn-dark px-4">
                <span>
                <i class="fas fa-money-bill me-2"></i> مراجعة المدفوعات
                </span>
                <i class="fas fa-credit-card fa-sm"></i>
            </a>
            <a asp-controller="Admin" asp-action="PageVisits" class="btn btn-dark px-4 mt-2">
                <span>
                <i class="fas fa-eye me-2"></i> سجل الصفحات
                </span>
                <i class="fas fa-file-alt fa-sm me-2"></i>
            </a>

           

            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                <a href="/ClientSettings/Index" class="btn btn-primary mb-3">
                    <span>

                    <i class="fas fa-eye me-2"></i>اعدادات
                    </span>
                    <i class="fas fa-cog ms-2" style="color:deeppink;"></i>

                </a>
               

            }
           <!-- <a asp-controller="AdminMenu" asp-action="AdminMenuSetting" class="btn btn-dark px-4 mt-2">
                <span>
                <i class="fas fa-eye me-2"></i>اعدادات
                </span>
                <i class="fas fa-cog ms-2" style="color:deeppink;"></i>
            </a>-->



            <hr style="border-color:rgba(255,255,255,.1); margin:10px 20px;" />
            <a asp-controller="Home" asp-action="Index">
                <span class="icon"><i class="fas fa-globe"></i></span> عرض الموقع
            </a>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:2px 10px;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn p-0 w-100 text-start d-flex align-items-center gap-2"
                        style="color:#9ca3af;padding:12px 10px!important;">
                    <span class="icon"><i class="fas fa-sign-out-alt"></i></span> تسجيل الخروج
                </button>
            </form>
        </nav>
    </div>
    <div id="overlay"></div>

    <!-- Main -->
    <div class="main-content">
        <div class="topbar">
            <button onclick="openMenu()" class="btn btn-dark">☰</button>
            <a href="/Home/Index" class="btn btn-outline-primary d-flex align-items-center">
                <i class="fas fa-home"></i>
            </a>
            <h5 class="mb-0 fw-bold">@ViewData["Title"]</h5>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-danger px-3 py-2">
                    <i class="fas fa-user-shield me-1"></i>مدير النظام
                </span>
            </div>
        </div>
        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible mb-4">
                    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

    <script>
        const sidebar = document.querySelector(".admin-sidebar");
        const overlay = document.getElementById("overlay");

        function openMenu() {
            sidebar.classList.add("active");
            overlay.classList.add("show");
        }

        function closeMenu() {
            sidebar.classList.remove("active");
            overlay.classList.remove("show");
        }

        overlay.addEventListener("click", closeMenu);
    </script>



</body>
</html>

