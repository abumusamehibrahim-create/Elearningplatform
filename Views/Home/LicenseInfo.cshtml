@model LicenseDashboardViewModel

<h2 class="mb-4">License Information</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <h4 class="text-primary">@Model.ClientName</h4>
        <p class="text-muted">@Model.Domain</p>

        <hr />

        <p><strong>License Key:</strong> @Model.LicenseKey</p>
        <p><strong>Expiration Date:</strong> @Model.ExpirationDate</p>

        @if (Model.ExpirationDate < DateTime.UtcNow)
        {
            <div class="alert alert-danger mt-3">
                Your license has expired.
            </div>
        }
        else
        {
            <div class="alert alert-info mt-3">
                Your license expires in <strong>@Model.DaysLeft</strong> days.
            </div>
        }

        @if (!Model.IsActive)
        {
            <div class="alert alert-danger mt-3">
                Your license is disabled.
            </div>
        }
        else if (Model.DaysLeft <= 30)
        {
            <div class="alert alert-warning mt-3">
                Your license will expire soon. Please renew.
            </div>
        }
        else
        {
            <div class="alert alert-success mt-3">
                License is active.
            </div>
        }

    </div>
</div>
