@model List<Course>
@{
    ViewData["Title"] = "الرئيسية";
}

<!-- Hero -->
<div class="hero text-center">
    <div class="container">
        <h1 class="display-4 fw-bold mb-3">
            <i class="fas fa-graduation-cap me-3"></i>تعلم بلا حدود
        </h1>
        <p class="lead mb-4">دورات افي مادت الرياضيات  - تعلم في أي وقت ومن أي مكان</p>
        <a href="#courses" class="btn btn-danger btn-lg px-5">
            <i class="fas fa-play me-2"></i>استكشف الدورات
        </a>
    </div>
</div>

<!-- Features -->
<div class="container my-5">
    <div class="row text-center g-4">
        <div class="col-md-4">
            <div class="p-4">
                <i class="fas fa-video fa-3x text-danger mb-3"></i>
                <h5>فيديوهات عالية الجودة</h5>
                <p class="text-muted">محتوى تعليمي احترافي يمكن مشاهدته في أي وقت</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <i class="fas fa-lock fa-3x text-danger mb-3"></i>
                <h5>محتوى حصري</h5>
                <p class="text-muted">وصول كامل بعد الدفع مع حساب خاص بك</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-4">
                <i class="fas fa-infinity fa-3x text-danger mb-3"></i>
                <h5>وصول مدى الحياة</h5>
                <p class="text-muted">ادفع مرة واحدة وشاهد محتواك للأبد</p>
            </div>
        </div>
    </div>
</div>

<!-- Courses -->
<div class="container mb-5" id="courses">
    <h2 class="text-center mb-4 fw-bold">
        <i class="fas fa-book-open me-2 text-danger"></i>الدورات المتاحة
    </h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
            <p class="text-muted">لا توجد دورات متاحة حالياً</p>
        </div>
    }

    <div class="row g-4">
        @foreach (var course in Model)
        {
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden h-100 position-relative">

                    <!-- صورة الكورس -->
                    <img src="~/thumbnails/@course.ThumbnailUrl"
                         alt="@course.Title"
                         class="w-100"
                         style="height: 260px; object-fit: cover;">

                    <!-- محتوى فوق الصورة -->
                    <div class="position-absolute bottom-0 start-0 end-0 p-3"
                         style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);">
                        <h5 class="fw-bold mb-2" style="color: #d60000;">@course.Title</h5>

                        <div class="d-flex align-items-center text-white-50 small mb-3">
                            <i class="fas fa-play-circle me-2 text-danger"></i>
                            <span>@course.Videos.Count فيديو</span>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Home" asp-action="CourseDetails" asp-route-id="@course.Id"
                               class="btn btn-light btn-sm fw-bold">
                                <i class="fas fa-info-circle me-2"></i>تفاصيل الكورس
                            </a>

                            <a asp-controller="Payment" asp-action="Checkout" asp-route-courseId="@course.Id"
                               class="btn btn-danger btn-sm fw-bold">
                                <i class="fas fa-shopping-cart me-2"></i>اشترك الآن - $@course.Price
                            </a>
                        </div>
                    </div>

                </div>
            </div>

        }
    </div>
</div>
