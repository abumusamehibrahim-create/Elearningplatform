@model License



<h2>Delete License</h2>

@if (TempData["SystemError"] != null)
{
    <div class="alert alert-danger">@TempData["SystemError"]</div>
}

<div class="alert alert-warning">
    Are you sure you want to delete this license?
</div>

<ul>
    <li><strong>Client:</strong> @Model.ClientName</li>
    <li><strong>Domain:</strong> @Model.Domain</li>
    <li><strong>Key:</strong> @Model.LicenseKey</li>
    <li><strong>Expiration:</strong> @Model.ExpirationDate</li>
</ul>

<form method="post" asp-action="DeleteConfirmed" asp-route-id="@Model.Id">
    <button class="btn btn-danger">Delete</button>
    <a href="/Licenses/Index" class="btn btn-secondary">Cancel</a>
</form>
