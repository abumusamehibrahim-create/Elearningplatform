@{
    Layout = "_Layout";
}
<h1>@ViewBag.Header</h1>

<section class="page-header">
    <h1><i class="fa-solid fa-list"></i> الأقسام</h1>

    @if (User.IsInRole("Admin"))
    {
        <a href="/AdminMenu/EditablePage?page=Categories" class="admin-edit-btn">
            <i class="fa-solid fa-pen-to-square"></i> تعديل الصفحة
        </a>

    }
</section>

<section class="page-content">

    <p>@ViewBag.Paragraph</p>

      <!--  تصفح جميع الأقسام التعليمية المتاحة في منصتنا، واختر المجال الذي يناسب اهتماماتك.
        نحن نعمل باستمرار على إضافة المزيد من المحتوى المتخصص.-->
    
</section>


<style>
    .page-header {
        background: linear-gradient(135deg, #ff4d4d, #ff9966);
        padding: 40px;
        border-radius: 18px;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: bold;
        }

    .admin-edit-btn {
        background: #fff;
        color: #d40000;
        padding: 10px 18px;
        border-radius: 12px;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s ease;
    }

        .admin-edit-btn:hover {
            background: #ffe6e6;
            transform: translateY(-3px);
        }

    .page-content {
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        line-height: 2;
        font-size: 18px;
    }
</style>
