@{
    ViewData["Title"] = "عنوان الصفحة";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4 p-4">

        <div class="text-center mb-4">
            <i class="fas fa-star fa-3x text-warning mb-3"></i>
            <h1 class="fw-bold text-danger">@ViewData["Title"]</h1>
            <p class="text-muted">مرحبًا بك في صفحة @ViewData["Title"] داخل المنصة التعليمية.</p>
        </div>

        <hr />

        <div class="content fs-5" style="line-height: 2;">
            <!-- ✨ ضع محتوى الصفحة هنا -->
            @{
                ViewData["Title"] = "جميع الصفحات";
            }

            <div class="container py-5">
                <div class="card shadow-lg border-0 rounded-4 p-4">
                    <h1 class="fw-bold text-danger mb-3">جميع الصفحات</h1>
                    <p class="fs-5">هذه صفحة لجميع المحتويات.</p>
                </div>
            </div>

            <p>
                هذا النص مثال. يمكنك تغييره بما يناسب صفحة @ViewData["Title"].
            </p>
        </div>

    </div>

</div>
