@{
    Layout = "_Layout";
}

<section class="page-header">
    <h1><i class="fa-solid fa-book-open"></i> الدورات</h1>

    @if (User.IsInRole("Admin"))
    {
        <a href="/AdminMenu/AdminMenuSetting" class="admin-edit-btn">
            <i class="fa-solid fa-pen-to-square"></i> تعديل الصفحة
        </a>
    }
</section>

<section class="page-content">
    <p>
        نوفر مجموعة واسعة من الدورات التدريبية المصممة بعناية لتناسب جميع المستويات.
        يمكنك البدء الآن وتطوير مهاراتك خطوة بخطوة.
    </p>
</section>



<style>
    .page-header {
        background: linear-gradient(135deg, #ff4d4d, #ff9966);
        padding: 40px;
        border-radius: 18px;
        color: #fff;
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: bold;
        }

    .admin-edit-btn {
        background: #fff;
        color: #d40000;
        padding: 10px 18px;
        border-radius: 12px;
        font-weight: bold;
        text-decoration: none;
        transition: 0.3s ease;
    }

        .admin-edit-btn:hover {
            background: #ffe6e6;
            transform: translateY(-3px);
        }

    .page-content {
        background: #fff;
        padding: 25px;
        border-radius: 16px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        line-height: 2;
        font-size: 18px;
    }
</style>
